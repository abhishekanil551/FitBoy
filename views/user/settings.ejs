            <div class="notification-item">
              <div class="notification-info">
                <label for="sms-orders">Order updates</label>
                <p>Receive SMS notifications about your order status.</p>
              </div>
              <label class="switch">
                <input type="checkbox" id="sms-orders" <%= user.notifications?.sms?.orderUpdates ? 'checked' : '' %>>
                <span class="slider"></span>
              </label>
            </div>
            
            <div class="notification-item">
              <div class="notification-info">
                <label for="sms-delivery">Delivery updates</label>
                <p>Receive SMS notifications about your delivery status.</p>
              </div>
              <label class="switch">
                <input type="checkbox" id="sms-delivery" <%= user.notifications?.sms?.deliveryUpdates ? 'checked' : '' %>>
                <span class="slider"></span>
              </label>
            </div>
            
            <div class="notification-item">
              <div class="notification-info">
                <label for="sms-marketing">Marketing messages</label>
                <p>Receive SMS notifications about promotions and sales.</p>
              </div>
              <label class="switch">
                <input type="checkbox" id="sms-marketing" <%= user.notifications?.sms?.marketing ? 'checked' : '' %>>
                <span class="slider"></span>
              </label>
            </div>
          </div>
          
          <button class="btn btn-primary" id="save-notifications-btn">Save Notification Settings</button>
        </div>
      </div>
    </div>
    
    <div class="tab-content" id="delete-tab">
      <div class="card card-danger">
        <div class="card-header">
          <div class="header-with-icon">
            <i class="fas fa-exclamation-triangle"></i>
            <h2>Delete Account</h2>
          </div>
          <p class="card-description">Permanently delete your account and all of your data. This action cannot be undone.</p>
        </div>
        <div class="card-content">
          <div class="warning-box">
            <p class="warning-title">Warning: This action is permanent</p>
            <ul class="warning-list">
              <li>All your personal information will be deleted</li>
              <li>All your saved addresses will be removed</li>
              <li>You will lose access to your purchase history</li>
              <li>This action cannot be reversed</li>
            </ul>
          </div>
          
          <form id="delete-account-form" class="form">
            <input type="hidden" name="_csrf" value="<%= csrfToken || '' %>">
            <% if (!user.googleId) { %>
            <div class="form-group">
              <label for="delete-password">Confirm your password</label>
              <input type="password" id="delete-password" name="password" placeholder="Enter your password">
              <div class="error-message" id="delete-password-error"></div>
            </div>
            <% } %>
            <button type="submit" class="btn btn-danger" id="delete-account-btn">Delete Account</button>
          </form>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Edit Address Modal -->
  <% if (editModalData) { %>
    <div class="modal" id="edit-address-modal">
      <div class="modal-content">
        <a href="/settings" class="close-modal">×</a>
        <h2 class="modal-header">Edit Address</h2>
        <form method="POST" action="/edit-address">
          <input type="hidden" name="_method" value="PUT">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="hidden" name="addressId" value="<%= editModalData._id %>">
          <div class="form-group">
            <label for="street">Street</label>
            <input type="text" name="street" id="street" value="<%= editModalData.street || '' %>" class="w-full border px-3 py-2 rounded" required>
          </div>
          <div class="form-group">
            <label for="city">City</label>
            <input type="text" name="city" id="city" value="<%= editModalData.city || '' %>" class="w-full border px-3 py-2 rounded" required>
          </div>
          <div class="form-group">
            <label for="state">State</label>
            <input type="text" name="state" id="state" value="<%= editModalData.state || '' %>" class="w-full border px-3 py-2 rounded">
