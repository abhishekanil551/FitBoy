        ordersList.innerHTML = `
            <div class="empty-state">
                <p>No orders found.</p>
            </div>
        `;
        return;
    }
    
    orders.forEach(order => {
        const orderDate = new Date(order.date);
        const formattedDate = orderDate.toLocaleDateString('en-US', { 
            year: 'numeric', 
            month: 'short', 
            day: 'numeric' 
        });
        
        // Create products HTML
        let productsHTML = '';
        order.products.forEach(product => {
            productsHTML += `
                <div class="order-product">
                    <div class="product-image">
                        <img src="${product.image}" alt="${product.name}">
                    </div>
                    <div class="product-details">
                        <div class="product-name">${product.name}</div>
                        <div class="product-price">$${product.price.toFixed(2)} x ${product.quantity}</div>
                    </div>
                </div>
            `;
        });
        
        // Create order actions based on status
        let orderActions = '';
        if (order.status === 'processing') {
            orderActions = `
                <div class="order-actions">
                    <button class="btn danger-btn cancel-order-btn" data-id="${order.id}">Cancel Order</button>
                </div>
            `;
        } else if (order.status === 'delivered') {
            orderActions = `
                <div class="order-actions">
                    <button class="btn secondary-btn return-order-btn" data-id="${order.id}">Return Order</button>
                </div>
            `;
        }
        
        const orderElement = document.createElement('div');
        orderElement.className = 'order-item';
        orderElement.innerHTML = `
            <div class="order-header">
                <div>
                    <span class="order-id">${order.id}</span>
                    <span class="order-date">${formattedDate}</span>
                </div>
                <span class="order-status status-${order.status}">${order.status.charAt(0).toUpperCase() + order.status.slice(1)}</span>
            </div>
            <div class="order-body">
                <div class="order-products">
                    ${productsHTML}
                </div>
                <div class="order-summary">
                    <span>Total:</span>
                    <span class="order-total">$${order.total.toFixed(2)}</span>
                </div>
                ${orderActions}
            </div>
        `;
        
        ordersList.appendChild(orderElement);
    });
    
    // Add event listeners to the buttons
    document.querySelectorAll('.cancel-order-btn').forEach(button => {
        button.addEventListener('click', function() {
            const orderId = this.getAttribute('data-id');
            cancelOrder(orderId);
        });
    });
    
    document.querySelectorAll('.return-order-btn').forEach(button => {
        button.addEventListener('click', function() {
            const orderId = this.getAttribute('data-id');
            returnOrder(orderId);
        });
    });
}

function filterOrders(status) {
    // In a real application, you would fetch filtered orders from your backend
    // For this example, we'll filter the mock data
    
    // Simulate API call delay
    setTimeout(() => {
        // Get all order items
        const orderItems = document.querySelectorAll('#ordersList .order-item');
        
        if (status === 'all') {
            // Show all orders
            orderItems.forEach(item => {
                item.style.display = 'block';
            });
        } else {
            // Filter orders by status
            orderItems.forEach(item => {
                const orderStatus = item.querySelector('.order-status').classList[1].replace('status-', '');
                if (orderStatus === status) {
                    item.style.display = 'block';
                } else {
                    item.style.display = 'none';
                }
            });
        }
        
        // Check if any orders are visible
        let visibleOrders = false;
        orderItems.forEach(item => {
            if (item.style.display !== 'none') {
                visibleOrders = true;
            }
        });
        
        // Show empty state if no orders are visible
        const ordersList = document.getElementById('ordersList');
        if (!visibleOrders) {
            // Check if empty state already exists
            if (!ordersList.querySelector('.empty-state')) {
                const emptyState = document.createElement('div');
                emptyState.className = 'empty-state';
                emptyState.innerHTML = `<p>No ${status} orders found.</p>`;
                ordersList.appendChild(emptyState);
            }
        } else {
            // Remove empty state if it exists
            const emptyState = ordersList.querySelector('.empty-state');
            if (emptyState) {
                emptyState.remove();
            }
        }
    }, 300);
}

function cancelOrder(orderId) {
    // In a real application, you would send a request to your backend
    // For this example, we'll simulate a successful cancellation
    
    if (confirm(`Are you sure you want to cancel order ${orderId}?`)) {
        // Find the order element
        const orderElement = document.querySelector(`.cancel-order-btn[data-id="${orderId}"]`).closest('.order-item');
        
        // Update the status
        const statusElement = orderElement.querySelector('.order-status');
        statusElement.className = 'order-status status-cancelled';
        statusElement.textContent = 'Cancelled';
        
        // Remove the cancel button
        const actionsElement = orderElement.querySelector('.order-actions');
        if (actionsElement) {
            actionsElement.remove();
        }
        
        alert(`Order ${orderId} has been cancelled.`);
    }
}

function returnOrder(orderId) {
    // In a real application, you would redirect to a return form
    // For this example, we'll show an alert
    
    alert(`To return order ${orderId}, please contact our customer support.`);
}

