  <!-- Add Address Modal -->
  <div class="modal" id="address-modal" style="display: none;">
    <div class="modal-content">
      <a href="/settings" class="close-modal">×</a>
      <h2 class="modal-header">Add New Address</h2>
      <form method="POST" action="/add-address" id="add-address-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="form-group">
          <label for="street">Street</label>
          <input type="text" name="street" id="street" class="w-full border px-3 py-2 rounded" required>
        </div>
        <div class="form-group">
          <label for="city">City</label>
          <input type="text" name="city" id="city" class="w-full border px-3 py-2 rounded" required>
        </div>
        <div class="form-group">
          <label for="state">State</label>
          <input type="text" name="state" id="state" class="w-full border px-3 py-2 rounded">
        </div>
        <div class="form-group">
          <label for="postalCode">Postal Code</label>
          <input type="text" name="postalCode" id="postalCode" class="w-full border px-3 py-2 rounded">
        </div>
        <div class="form-group">
          <label for="country">Country</label>
          <input type="text" name="country" id="country" class="w-full border px-3 py-2 rounded">
