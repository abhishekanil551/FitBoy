          <div class="form-group">
            <label for="postalCode">Postal Code</label>
            <input type="text" name="postalCode" id="postalCode" value="<%= editModalData.postalCode || '' %>" class="w-full border px-3 py-2 rounded">
          </div>
          <div class="form-group">
            <label for="country">Country</label>
            <input type="text" name="country" id="country" value="<%= editModalData.country || '' %>" class="w-full border px-3 py-2 rounded">
