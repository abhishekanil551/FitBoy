function setDefaultAddress(addressId) {
    // In a real application, you would send a request to your backend
    // For this example, we'll simulate a successful update
    
    // Remove default class and badge from all addresses
    document.querySelectorAll('.address-item').forEach(item => {
        item.classList.remove('default');
        const badge = item.querySelector('.default-badge');
        if (badge) badge.remove();
        
        // Show "Set as Default" button for all addresses
        const setDefaultBtn = document.createElement('button');
        setDefaultBtn.className = 'btn secondary-btn set-default-btn';
        setDefaultBtn.setAttribute('data-id', item.dataset.id);
        setDefaultBtn.textContent = 'Set as Default';
        setDefaultBtn.addEventListener('click', function() {
            setDefaultAddress(this.getAttribute('data-id'));
        });
        
        const actions = item.querySelector('.address-actions');
        const existingSetDefaultBtn = actions.querySelector('.set-default-btn');
        if (!existingSetDefaultBtn) {
            actions.appendChild(setDefaultBtn);
        }
    });
    
    // Set the selected address as default
    const selectedAddress = document.querySelector(`.address-item[data-id="${addressId}"]`);
    if (selectedAddress) {
        selectedAddress.classList.add('default');
        
        // Add default badge
        const badge = document.createElement('span');
        badge.className = 'default-badge';
        badge.textContent = 'Default';
        selectedAddress.prepend(badge);
        
        // Remove "Set as Default" button
        const setDefaultBtn = selectedAddress.querySelector('.set-default-btn');
        if (setDefaultBtn) setDefaultBtn.remove();
        
        // Update default address in profile section
        const addressLines = selectedAddress.querySelectorAll('p');
        document.getElementById('street').textContent = addressLines[0].textContent;
        const cityStateZip = addressLines[1].textContent.split(', ');
        document.getElementById('city').textContent = cityStateZip[0];
        const stateZip = cityStateZip[1].split(' ');
        document.getElementById('state').textContent = stateZip[0];
        document.getElementById('postalCode').textContent = stateZip[1];
        document.getElementById('country').textContent = addressLines[2].textContent;
    }
}

function saveAddress() {
    const addressId = document.getElementById('addressId').value;
    const street = document.getElementById('street').value;
    const city = document.getElementById('city').value;
    const state = document.getElementById('state').value;
    const postalCode = document.getElementById('postalCode').value;
    const country = document.getElementById('country').value;
    const isDefault = document.getElementById('isDefault').checked;
    
    const addressData = {
        id: addressId || Date.now().toString(), // Generate a new ID if not editing
        street: street,
        city: city,
        state: state,
        postalCode: postalCode,
        country: country,
        isDefault: isDefault
    };
    
    // In a real application, you would send this data to your backend
    // For this example, we'll simulate a successful save
    
    // Update the UI
    if (addressId) {
        // Update existing address
        const addressElement = document.querySelector(`.address-item[data-id="${addressId}"]`);
        if (addressElement) {
            // If this is now the default address, update all addresses
            if (isDefault) {
                setDefaultAddress(addressId);
            }
            
            // Update the address details
            const lines = addressElement.querySelectorAll('p');
            lines[0].textContent = street;
            lines[1].textContent = `${city}, ${state} ${postalCode}`;
            lines[2].textContent = country;
        }
    } else {
        // Add new address
        const addresses = Array.from(document.querySelectorAll('.address-item')).map(item => {
            const id = item.dataset.id;
            const isDefault = item.classList.contains('default');
            const lines = item.querySelectorAll('p');
            
            return {
                id: id,
                street: lines[0].textContent,
                city: lines[1].textContent.split(', ')[0],
                state: lines[1].textContent.split(', ')[1].split(' ')[0],
                postalCode: lines[1].textContent.split(', ')[1].split(' ')[1],
                country: lines[2].textContent,
                isDefault: isDefault
            };
        });
        
        // Add the new address
        addresses.push(addressData);
        
        // If this is the default address, update all other addresses
        if (isDefault) {
            addresses.forEach(addr => {
                if (addr.id !== addressData.id) {
                    addr.isDefault = false;
                }
            });
        }
        
        // Update the UI
        updateAddressList(addresses);
    }
    
    // Hide the form
    hideAddressForm();
}

// Settings Functions
function changePassword() {
    const currentPassword = document.getElementById('currentPassword').value;
    const newPassword = document.getElementById('newPassword').value;
    const confirmPassword = document.getElementById('confirmPassword').value;
    
    // Validate passwords
    if (!currentPassword || !newPassword || !confirmPassword) {
        alert('Please fill in all password fields');
        return;
    }
    
    if (newPassword !== confirmPassword) {
        alert('New password and confirmation do not match');
        return;
    }
    
    // Check password strength
    if (newPassword.length < 8) {
        alert('Password must be at least 8 characters long');
        return;
    }
    
    // Simple regex for password strength
    const passwordRegex = /^(?=.*[A-Za-z])(?=.*\d)(?=.*[@$!%*#?&])[A-Za-z\d@$!%*#?&]{8,}$/;
    if (!passwordRegex.test(newPassword)) {
        alert('Password must include at least one letter, one number, and one special character');
        return;
    }
    
    // In a real application, you would send this data to your backend
    // For this example, we'll simulate a successful password change
    
    // Simulate API call delay
    setTimeout(() => {
        alert('Password changed successfully!');
        document.getElementById('changePasswordForm').reset();
    }, 1000);
}

