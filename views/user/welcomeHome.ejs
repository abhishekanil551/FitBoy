         /* Scroll Down Button Styles */
    .scroll-down-container {
      position: absolute;
      bottom: 30px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 10;
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.5s ease, visibility 0.5s ease;
    }
    
    .scroll-down-container.visible {
      opacity: 1;
      visibility: visible;
    }
    
    .scroll-down-button {
      display: flex;
      flex-direction: column;
      align-items: center;
      cursor: pointer;
      background: transparent;
      border: none;
      color: white;
      font-size: 0.9rem;
      font-weight: 500;
      letter-spacing: 1px;
      text-transform: uppercase;
    }
    
    .scroll-down-arrow {
      margin-top: 8px;
      width: 40px;
      height: 40px;
      border: 2px solid rgba(255, 255, 255, 0.8);
      border-radius: 50%;
      position: relative;
      display: flex;
      justify-content: center;
      align-items: center;
      animation: pulse-border 2s infinite;
    }
    
    .scroll-down-arrow::after {
      content: '';
      width: 10px;
      height: 10px;
      border-right: 2px solid white;
      border-bottom: 2px solid white;
      transform: rotate(45deg) translateY(-2px);
    }
    
    @keyframes bounce-arrow {
      0%, 20%, 50%, 80%, 100% {
        transform: translateY(0);
      }
      40% {
        transform: translateY(-10px);
      }
      60% {
        transform: translateY(-5px);
      }
    }
    
    .scroll-down-arrow {
      animation: bounce-arrow 2s infinite;
    }
    
    /* Responsive adjustments for scroll button */
    @media (max-width: 768px) {
      .scroll-down-container {
        bottom: 20px;
      }
      
      .scroll-down-button {
        font-size: 0.8rem;
      }
      
      .scroll-down-arrow {
        width: 25px;
        height: 25px;
      }
    }
    
    @media (max-width: 480px) {
      .scroll-down-container {
        bottom: 15px;
      }
      
      .scroll-down-button {
        font-size: 0.7rem;
      }
      
      .scroll-down-arrow {
        width: 22px;
        height: 22px;
      }
    }
      
      /* Logo animation */
      @keyframes logo-pulse {
        0% { text-shadow: 0 0 2px #ff0000, 0 0 4px rgba(255, 0, 0, 0.7); }
        50% { text-shadow: 0 0 10px #ff0000, 0 0 15px rgba(255, 0, 0, 0.9); }
        100% { text-shadow: 0 0 2px #ff0000, 0 0 4px rgba(255, 0, 0, 0.7); }
      }
      
      .logo.animated {
        animation: logo-pulse 2s infinite;
      }
      
      /* Star animation */
      @keyframes star-twinkle {
        0% { opacity: 0.5; transform: translateX(-50%) scale(0.8); }
        50% { opacity: 1; transform: translateX(-50%) scale(1.2); }
        100% { opacity: 0.5; transform: translateX(-50%) scale(0.8); }
      }
      
      .star.animated {
        animation: star-twinkle 1.5s infinite;
      }

      /* Particle effects */
      .particles-container {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 0;
      }
      
      .particle {
        position: absolute;
        background-color: rgba(255, 255, 255, 0.5);
